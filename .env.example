PORT=3000
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-public-anon-key

# Public base URL the app is served from (used to build the Paymob return URL).
# In local sandbox testing this must be a PUBLIC tunnel (e.g. ngrok), not
# localhost, so Paymob can redirect the browser back and reach the webhook.
APP_BASE_URL=http://localhost:3000

# ── Paymob (card payments) — see docs/PAYMOB.md ──
# Use the sandbox/test keys first. Leaving these blank disables card checkout
# (the Card option returns 503; COD / wallet checkout is unaffected).
PAYMOB_API_BASE=https://accept.paymob.com
PAYMOB_SECRET_KEY=egy_sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYMOB_PUBLIC_KEY=egy_pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYMOB_HMAC_SECRET=your-hmac-secret-from-dashboard
# Comma-separated integration IDs for the payment methods you enabled
# (card, and optionally wallet). Numbers only, e.g. 123456 or 123456,123457
PAYMOB_INTEGRATION_IDS=123456

# ── Account-security OTP (password / email / phone changes) — see docs/SECURITY-OTP.md ──
# Codes are emailed via SMTP. Until SMTP_HOST is set, the flow still works in
# development: the code is logged to the server console (and returned to the
# client ONLY when NODE_ENV != production). Set these for real email delivery.
SMTP_HOST=
SMTP_PORT=587
# SMTP_SECURE=true       # set for port 465 (implicit TLS); 587 uses STARTTLS
SMTP_USER=
SMTP_PASS=
SMTP_FROM=TIBR <no-reply@yourdomain.com>
# Optional: dedicated pepper for hashing OTP codes at rest. Falls back to the
# service-role key if unset. OTP_TTL_MINUTES defaults to 10.
# OTP_PEPPER=
# OTP_TTL_MINUTES=10
